{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nde_context_output",
  "type": "object",
  "additionalProperties": false,
  "required": ["context"],
  "properties": {
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tone", "evidence_segments"],
      "properties": {
        "tone": {
          "type": "string",
          "enum": ["positive", "negative", "mixed", "neutral"]
        },
        "evidence_segments": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "maxItems": 3
        }
      }
    }
  }
}
