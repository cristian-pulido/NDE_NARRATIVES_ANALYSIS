{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nde_experience_output",
  "type": "object",
  "additionalProperties": false,
  "required": ["experience"],
  "properties": {
    "experience": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tone",
        "evidence_segments",
        "m8_out_of_body",
        "m8_bright_light",
        "m8_peace",
        "m8_time_distortion",
        "m8_presence"
      ],
      "properties": {
        "tone": {
          "type": "string",
          "enum": ["positive", "negative", "mixed", "neutral"]
        },
        "evidence_segments": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "maxItems": 3
        },
        "m8_out_of_body": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "m8_bright_light": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "m8_peace": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "m8_time_distortion": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "m8_presence": {
          "type": "string",
          "enum": ["yes", "no"]
        }
      }
    }
  }
}
