{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nde_experience_output",
  "type": "object",
  "additionalProperties": false,
  "required": ["experience"],
  "properties": {
    "experience": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tone",
        "evidence_segments",
        "outside_of_body_experience",
        "feeling_bright_light",
        "feeling_awareness",
        "presence_encounter",
        "saw_relived_past_events",
        "time_perception_altered",
        "border_point_of_no_return",
        "non_existence_feeling",
        "feeling_peace_wellbeing",
        "saw_entered_gateway"
      ],
      "properties": {
        "tone": {
          "type": "string",
          "enum": ["positive", "negative", "mixed", "neutral"]
        },
        "evidence_segments": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "maxItems": 3
        },
        "outside_of_body_experience": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "feeling_bright_light": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "feeling_awareness": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "presence_encounter": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "saw_relived_past_events": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "time_perception_altered": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "border_point_of_no_return": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "non_existence_feeling": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "feeling_peace_wellbeing": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "saw_entered_gateway": {
          "type": "string",
          "enum": ["yes", "no"]
        }
      }
    }
  }
}
