        },
        "spiritual_feelings": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "desire_to_help_others": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "personal_vulnerability": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "interest_in_material_goods": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "interest_in_religion": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "understanding_myself": {
          "type": "string",
          "enum": ["yes", "no"]
        },
        "social_justice_issues": {
          "type": "string",
          "enum": ["yes", "no"]
        }
